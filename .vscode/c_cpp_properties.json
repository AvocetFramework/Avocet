{
    "configurations": [
        {
            "name": "MSYS2-MinGW64",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/kernel/include",
                "C:/msys64/mingw64/include",
                "C:/msys64/mingw64/include/python3.14"
